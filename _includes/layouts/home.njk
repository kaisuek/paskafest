---
section: home
---

<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/assets/css/inline.css">
  <title>{{ title }}</title>
</head>
<body>

<section id="banneri" style="width: 100vw; margin: 0; padding: 0; overflow: hidden;">
  <img 
    src="/static/img/paskafest.jpg" 
    alt="Paskafest 2025 -banneri" 
    style="width: 100%; height: auto; display: block; max-width: 100vw;">
</section>

<header id="otsikko" style="text-align: center; width: 100%;">
  <h1>Paskafest 9.8.2025 Viikin paska-altaalla</h1>
</header>

  <section id="teksti" style="text-align: center; width: 100%;">
    <p>{{ hero_text }}</p>
  </section>

  <section id="artists">
    <h2>Esiintyjät</h2>
    <p>{{ artists }}</p>
  </section>

  <section id="location">
    <h2>Sijaintina Viikin paska-allas</h2>
    <p>{{ location }}</p>
  </section>

  <section id="info">
    <h2>Uutisointi</h2>
    <p>
      <a href="{{ instagram_url }}" target="_blank">Instagram</a>
      <a href="{{ telegram_url }}" target="_blank">Telegram</a>
    </p>
  </section>

<section id="gif-line" style="display: flex; justify-content: center; flex-wrap: wrap;"></section>
<script>
  const gifContainer = document.getElementById("gif-line");
  const gifSize = 50; // px
  const screenWidth = window.innerWidth - 50; // give it some room for padding/margins
  const gifsPerRow = Math.floor(screenWidth / gifSize);

  for (let i = 0; i < gifsPerRow; i++) {
    const gif = document.createElement("img");
    gif.src = "static/img/paska.GIF";
    gif.alt = "Paska gif";
    gif.style.width = gifSize + "px";
    gif.style.height = gifSize + "px";
    gif.style.objectFit = "cover";
    gifContainer.appendChild(gif);
  }
</script>


  {# Optionally render extra markdown content, if any #}
  {{ layoutContent | safe }}

</body>
</html>

