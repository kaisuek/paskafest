<!DOCTYPE html>
<html lang="fi">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="_includes/assets/css/inline.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <title>Paskafest 9.8.2025 Viikin paska-altaalla</title>
  <description>Paskafest tulee jälleen! Elokuussa jo toista kertaa järjestettävä mielenosoitus vaatii tänäkin vuonna Lisää ilmaista paskaa Helsinkiin</description>
</head>
<script src="_includes/assets/js/inline.js" defer></script>
<body>

<section id="banneri" style="width: 100vw; margin: 0; padding: 0; overflow: hidden;">
  <img 
    src="static/img/paskafest-2025-hero.JPG" 
    alt="Paskafest 9.8.2025 -mielenosoitusbanneri" 
    style="width: 100%; height: auto; display: block; max-width: 100vw;">
</section>

<header id="otsikko" style="text-align: center; width: 100%;">
  <h1>Paskafest 9.8.2025 Viikin paska-altaalla</h1>
</header>

  <section id="teksti">
    <p>{{ hero_text }}</p>
  </section>

<section class="artist-gallery-wrapper">
  <h2>Esiintyjät</h2>
  <p>{{ artists }}</p>

  <div class="artist-gallery-container">
    <button class="scroll-btn left" aria-label="Selaa vasemmalle">←</button>

    <div class="artist-gallery" id="artistGallery">
      <div class="artist-track" id="artistTrack">
        <!-- Artistikortit -->
        <div class="artist">
          <h3>Kaisu and the vappupillis</h3>
          <img 
            src="static/img/kaisu-and-the-vappupillis.jpg" 
            alt="Kaisu and the vappupillis kuva">
          <p>Diesel vetoinen free jazz avant garde kazoo bile orkesteri – älä odota mitään, valmistaudu kaikkeen</p>
          <div class="artist-links">
            <a href="https://www.instagram.com/kaisuvappupillis/" target="_blank" rel="noreferrer noopener">Instagram</a>
            <a href="https://soundcloud.com/kaisu-and-the-vappupillis"target="_blank" rel="noreferrer noopener">Soundcloud</a>
          </div>
        </div>

        <div class="artist">
          <h3>fooly (HKI)</h3>
          <img src="static/img/fooly.png" alt="fooly kuva">
          <p>fooly on vuonna 2020 perustettu nelihenkinen yhtye jonka musiikissa on kuultavissa vaikutteita niin amerikkalaisista surisevista indie-klassikoista kuin brittien shoegaze-perinteestäkin, kotimaisia vaikutteita unohtamatta. Yhtye julkaisi kuuden biisin debyytti-EPnsä "Haven't felt that great lately" kesällä 2023 ja nauhoittaa parhaillaan seuraavaa julkaisuaan.</p>
          <div class="artist-links">
            <a href="https://www.instagram.com/foolytheband" target="_blank" rel="noreferrer noopener">Instagram</a>
            <a href="https://youtu.be/65ueCxkB_g8?si=WAlMYNxfpEvhKxet" target="_blank" rel="noreferrer noopener">Youtube</a>
	<a href="https://fooly.bandcamp.com/track/sour-winds" target="_blank" rel="noreferrer noopener">Bandcamp</a>
          </div>
        </div>

        <div class="artist">
          <h3>Masa ja Ullis</h3>
          <img 
            src="static/img/masa-ja-ullis.jpeg" 
            alt="Masa ja Ullis kuva">
          <p>Paskaa räppii Helsingin kujilta tuu kattoo ni tiiät!:)</p>
	<div class="artist-links">
            <a href="#" target="_blank" rel="noreferrer noopener"></a>
            <a href="#"target="_blank" rel="noreferrer noopener"></a>
          </div>
        </div>

	<div class="artist">
          <h3>Ocean Days of Eagle</h3>
          <img 
            src="static/img/ocean-days-of-eagle.jpeg" 
            alt="Ocean Days of Eagle kuva">
          <p>Ocean Days of Eagle on nimestään huolimatta Helsingin lähiöistä ponnistava raskaan musiikin yhtye, jonka musiikin tahtiin voi yhtä lailla nyökyttää päätä, pyörittää pittiä tai vaikka tanssia valssia.</p>
	<div class="artist-links">
            <a href="#" target="_blank" rel="noreferrer noopener"></a>
            <a href="#"target="_blank" rel="noreferrer noopener"></a>
          </div>
        </div>

	<div class="artist">
          <h3>Karhumies</h3>
          <img 
            src="static/img/karhumies.jpg" 
            alt="Karhumies kuva">
          <p>Karhumies riimeillään ronskeja asioita kaunistava artisti, jonka pop on varustettu göstamaisella kulmalla ja rock taas juicemaisella vinoudella.</p>
	<div class="artist-links">
            <a href="#" target="_blank" rel="noreferrer noopener"></a>
            <a href="#"target="_blank" rel="noreferrer noopener"></a>
          </div>
        </div>

	<div class="artist" id="seppo">
          <h3>Seppo Frigo (TKU) (DJ set)</h3>
          <img 
            src="static/img/seppo-frigo.jpg" 
            alt="Seppo Frigo kuva">
          <p>”Dekin takana mun lemppari DJ <br /> Ja se soittaa meille vain hyvii biisei"</p>
          <p>©Jukka Poika</p>
	<div class="artist-links">
            <a href="#" target="_blank" rel="noreferrer noopener"></a>
            <a href="#"target="_blank" rel="noreferrer noopener"></a>
          </div>
        </div>

        <!-- Lisää artisteja tähän -->
      </div>
    </div>

    <button class="scroll-btn right" aria-label="Selaa oikealle">→</button>
  </div>
</section>


  <section id="location" style="position: relative; overflow: hidden;">
  <h2>Sijaintina Viikin paska-allas</h2>
  <p>{{ location }}</p>

  <!-- Google Maps iframe -->
  <div style="position: relative; z-index: 1;">
    <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d1347.8864757105766!2d25.030884428488246!3d60.217556110892595!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e1!3m2!1sfi!2sfi!4v1747999812052!5m2!1sfi!2sfi"
      width="100%" height="450" style="border:0;" allowfullscreen="" loading="lazy"
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>
  </div>

  <!-- Emoji container -->
  <div id="poop-emojis" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 2;"></div>

  <script>
    function createPoopEmoji() {
      const emoji = document.createElement('div');
      emoji.textContent = '💩';
      emoji.style.position = 'absolute';
      emoji.style.left = Math.random() * 100 + '%';
      emoji.style.bottom = '-30px';
      emoji.style.fontSize = '100px';
      emoji.style.opacity = '1';
      emoji.style.animation = `floatUp ${3 + Math.random() * 2}s linear forwards`;
      document.getElementById('poop-emojis').appendChild(emoji);

      setTimeout(() => emoji.remove(), 6000); // Clean up
    }

    setInterval(createPoopEmoji, 500); // Spawn one every 0.5 sec
  </script>

  <style>
    @keyframes floatUp {
      0% {
        transform: translateY(0);
        opacity: 0.8;
      }
      100% {
        transform: translateY(-100vh);
        opacity: 0;
      }
    }
  </style>
</section>


  <section id="info">
    <h2>Tiedotusta</h2>
    <p>
      <a href="{{ instagram_url }}" target="_blank" rel="noreferrer noopener">Instagram</a>
      <a href="{{ telegram_url }}" target="_blank" rel="noreferrer noopener">Telegram</a>
    </p>
  </section>

<section id="gif-line" style="display: flex; justify-content: center; flex-wrap: wrap;"></section>
<script>
  const gifContainer = document.getElementById("gif-line");
  const gifSize = 50; // px
  const screenWidth = window.innerWidth - 50; // give it some room for padding/margins
  const gifsPerRow = Math.floor(screenWidth / gifSize);

  for (let i = 0; i < gifsPerRow; i++) {
    const gif = document.createElement("img");
    gif.src = "static/img/paska.GIF";
    gif.alt = "Paska gif";
    gif.style.width = gifSize + "px";
    gif.style.height = gifSize + "px";
    gif.style.objectFit = "cover";
    gifContainer.appendChild(gif);
  }
</script>


  {# Optionally render extra markdown content, if any #}
  {{ layoutContent | safe }}

<div class="poop-container"></div>

<script>
  const poopContainer = document.querySelector('.poop-container');

  function createPoop() {
    const poop = document.createElement('div');
    poop.classList.add('poop');
    poop.textContent = '💩';
    poop.style.left = Math.random() * window.innerWidth + 'px';
    poop.style.animationDuration = (5 + Math.random() * 10) + 's';
    poopContainer.appendChild(poop);

    // Poista kun animaatio päättyy
    setTimeout(() => poop.remove(), 15000);
  }

  // Luo emojit jatkuvasti hitaalla tahdilla
  setInterval(createPoop, 800);
</script>


</body>
</html>

